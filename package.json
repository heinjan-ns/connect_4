{
  "name": "connect_4",
  "version": "1.0.0",
  "description": "",
  "main": "jest.config.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "test": "npm run test:unit && npm run test:cucumber && npm run smoketest",
    "test:unit": "vitest run",
    "test:cucumber": "cucumber-js tests/features/**/*.feature --require-module ts-node/register --require tests/features/**/*.ts",
    "test:cucumber:coverage": "c8 cucumber-js tests/features/**/*.feature --require-module ts-node/register --require tests/features/**/*.ts",
    "test:cucumber:watch": "nodemon --watch src --watch tests --ext ts,feature --exec 'npm run test:cucumber:coverage'",
    "smoketest": "ts-node tests/main.smoketest.ts",
    "build": "tsc",
    "start": "node dist/src/main.js",
    "dev": "ts-node src/main.ts",
    "prepare": "[ -n \"$CI\" ] || husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^12.3.0",
    "@types/node": "^24.10.2",
    "@types/prompt-sync": "^4.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "@vitest/coverage-v8": "^4.0.18",
    "c8": "^10.1.3",
    "eslint": "^9.39.2",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "nodemon": "^3.1.11",
    "prompt-sync": "^4.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
