{
  "name": "connect_4",
  "version": "1.0.0",
  "description": "",
  "main": "jest.config.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "test": "jest --coverage",
    "test:cucumber": "cucumber-js tests/features/**/*.feature --require-module ts-node/register --require tests/features/**/*.ts",
    "test:cucumber:coverage": "nyc cucumber-js tests/features/**/*.feature --require-module ts-node/register --require tests/features/**/*.ts",
    "test:cucumber:watch": "nodemon --watch src --watch tests --ext ts,feature --exec 'npm run test:cucumber:coverage'",
    "build": "tsc",
    "start": "node dist/src/main.js",
    "dev": "ts-node src/main.ts",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@cucumber/cucumber": "^12.3.0",
    "@cucumber/pretty-formatter": "^2.4.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.10.2",
    "@types/prompt-sync": "^4.2.3",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.2.0",
    "jiti": "^2.6.1",
    "nodemon": "^3.1.11",
    "nyc": "^17.1.0",
    "prompt-sync": "^4.2.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "ts-node": "^10.9.2"
  }
