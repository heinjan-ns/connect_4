{
    "compilerOptions": {
      "outDir": "./dist",
      "sourceMap": true,
      "noImplicitAny": true,
      "strictNullChecks": true,
      "module": "commonjs",
      "target": "es6",
      "skipLibCheck": true,
      "esModuleInterop": true
    },
    "include": ["src/**/*", "tests/**/*"],
    "exclude": ["node_modules", "dist"]
}
